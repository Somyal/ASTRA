{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "opener:default",
    "sql:allow-execute",
    "sql:allow-select",
    "sql:allow-load",
    "core:window:allow-set-fullscreen",
    "core:window:allow-set-always-on-top",
    "core:window:allow-set-size"
  ]
}
